# TMap monorepo — local dev environment.
# Copy to .env before starting the database:   cp .env.example .env
#
# ── PostgreSQL (consumed by docker-compose.yml) ──────────────────────────────
# This database is bound to 127.0.0.1 only (see docker-compose.yml) and is a
# throwaway local dev DB. These are NOT production secrets; production credentials
# live in a secret manager (see SP5). Override these values freely for your machine.
POSTGRES_USER=tmap
POSTGRES_PASSWORD=tmap_dev_pw
POSTGRES_DB=tmap

# ── .NET API ─────────────────────────────────────────────────────────────────
# The API listens on http://localhost:5188 in dev (the `http` profile in
# backend/src/Tmap.Api/Properties/launchSettings.json). The connection string is
# set in backend/src/Tmap.Api/appsettings.Development.json or via user-secrets:
#   dotnet user-secrets set "ConnectionStrings:Default" "..."

# ── Desktop renderer (apps/desktop) ──────────────────────────────────────────
# API base URL for the renderer. The VITE_ prefix exposes it to renderer code via
# import.meta.env. Defaults to http://localhost:5188 when unset.
VITE_API_BASE_URL=http://localhost:5188

# ── Desktop main process (apps/desktop/electron) ─────────────────────────────
# API base URL for the secureStore:refreshAndGetAccess IPC handler (refresh token
# custody lives in main). Set as an OS env var or in a .env the main process loads.
# Keep in sync with VITE_API_BASE_URL above. Defaults to http://localhost:5188.
TMAP_API_BASE_URL=http://localhost:5188
