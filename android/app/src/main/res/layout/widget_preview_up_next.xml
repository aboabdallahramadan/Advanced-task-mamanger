<?xml version="1.0" encoding="utf-8"?>
<!-- Static launcher-picker preview for the Up Next widget.
     RemoteViews-safe (LinearLayout/TextView only). Midnight Calm dark.
     Hardcoded hex is intentional: previews cannot use the runtime theme. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="146dp"
    android:layout_height="110dp"
    android:background="@drawable/widget_preview_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:letterSpacing="0.08"
        android:text="UP NEXT"
        android:textColor="#E8A87C"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="Deep work block"
        android:textColor="#ECEAE4"
        android:textSize="15sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_preview_amber_pill"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="Focus"
        android:textColor="#1A1B20"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
