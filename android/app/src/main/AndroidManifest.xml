<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Android 11+ package visibility: allow querying the system speech recognizer. -->
    <queries>
        <intent>
            <action android:name="android.speech.action.RECOGNIZE_SPEECH" />
        </intent>
    </queries>

    <application
        android:name=".TmapApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TMap"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.TMap">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Widget deep-links (P8): tmap://task/{id}, tmap://today, tmap://focus/{taskId?},
                 tmap://capture — all route to MainActivity; SheetHost/NavHost dispatch them. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="tmap" android:host="task" />
                <data android:scheme="tmap" android:host="today" />
                <data android:scheme="tmap" android:host="focus" />
                <data android:scheme="tmap" android:host="capture" />
            </intent-filter>
        </activity>

        <!-- Share-sheet target (Feature 1): receives ACTION_SEND text/plain from other apps and
             saves the shared link/text as a note WITHOUT opening the app. Translucent + excluded
             from Recents + empty taskAffinity so it never adopts the sharing app's task. text/plain
             only — TMap intentionally does not appear for image/video shares it cannot store. -->
        <activity
            android:name=".share.ShareReceiverActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:label="@string/app_name"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Fired by ReminderScheduler's exact alarm; not exported (internal PendingIntent only). -->
        <receiver
            android:name=".notifications.AlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="net.qmindtech.tmap.action.REMINDER_FIRE" />
            </intent-filter>
        </receiver>

        <!-- Keeps the focus timer alive in the background via a silent ongoing notification (spec §6.5). -->
        <service
            android:name=".ui.focus.FocusService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Re-arms alarms after reboot. exported=true is required for the system BOOT_COMPLETED broadcast. -->
        <receiver
            android:name=".notifications.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Today Agenda home-screen widget (P8.6). exported=true is required: the AppWidget host
             system service binds this receiver to deliver APPWIDGET_UPDATE and related broadcasts.
             The provider XML defines size constraints, resize behaviour, and update interval. -->
        <receiver
            android:name=".widget.TodayAgendaWidgetReceiver"
            android:exported="true"
            android:label="TMap — Today">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_today_agenda" />
        </receiver>

        <!-- Quick Capture 1-row home-screen widget (P8.7). exported=true is required: the AppWidget
             host system service binds this receiver to deliver APPWIDGET_UPDATE broadcasts.
             updatePeriodMillis=0 because the capture bar has no dynamic content to refresh. -->
        <receiver
            android:name=".widget.QuickCaptureWidgetReceiver"
            android:exported="true"
            android:label="TMap — Quick Capture">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quick_capture" />
        </receiver>

        <!-- Up Next / Focus 2×2 home-screen widget (P8.8). Shows the next incomplete task and a
             one-tap "◉ Focus" button that deep-links to tmap://focus/{taskId}. The live-countdown
             branch is stubbed (focusRemainingLabel always null) — see TODO(P6) in UpNextFocusWidget.
             exported=true is required: the AppWidget host system service binds this receiver. -->
        <receiver
            android:name=".widget.UpNextFocusWidgetReceiver"
            android:exported="true"
            android:label="TMap — Up Next">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_up_next" />
        </receiver>

        <!-- Progress & Streak 2×2 home-screen widget (P8.9). Shows today's completion ring (amber
             arc bitmap, built via ProgressRingBitmap), a center "%" label, "🔥 N-day streak", and
             "X of Y done today". Tap → tmap://today. exported=true is required: the AppWidget host
             system service binds this receiver to deliver APPWIDGET_UPDATE broadcasts. -->
        <receiver
            android:name=".widget.ProgressStreakWidgetReceiver"
            android:exported="true"
            android:label="TMap — Progress">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_progress_streak" />
        </receiver>

        <!-- Trampoline for the Quick Capture widget. Launched by class ref (not VIEW filter); opens
             the system speech recognizer on mic tap, then forwards tmap://capture to MainActivity. -->
        <activity
            android:name=".widget.CaptureTrampolineActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Trampoline for the Quick-add Note widget. Launched by class ref (not a VIEW filter);
             opens the system speech recognizer on mic tap, or the QuickNoteOverlay on body tap. -->
        <activity
            android:name=".widget.NoteCaptureTrampolineActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Disable the default WorkManager initializer so TmapApplication's
             Configuration.Provider (with the HiltWorkerFactory) drives WorkManager. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>
