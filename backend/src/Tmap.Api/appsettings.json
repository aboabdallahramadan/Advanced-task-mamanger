{
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [{ "Name": "Console" }],
    "Enrich": ["FromLogContext"]
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Jwt": {
    "Issuer": "tmap",
    "Audience": "tmap-clients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 60,
    "ActiveKeyId": "key-1",
    "SigningKeys": {
      "key-1": "REPLACE-IN-SECRETS-OR-ENV-minimum-32chars"
    }
  },
  "AllowedHosts": "*"
}
