# Production API origin baked into packaged desktop builds.
# Vite loads .env.production only in production mode (`npm run build`/`package`),
# so `npm run dev` still defaults to http://localhost:5188 (local .NET API).
# Keep both vars in sync — the renderer reads VITE_API_BASE_URL, the Electron
# main process (refresh/logout IPC) reads the same value baked at build time.
VITE_API_BASE_URL=https://api-tasks.qmindtech.net
TMAP_API_BASE_URL=https://api-tasks.qmindtech.net
